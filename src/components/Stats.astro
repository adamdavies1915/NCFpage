---
const stats = [
  { number: '53.4%', label: 'of NOLA roadway fatalities are pedestrians & cyclists', accent: 'rust' },
  { number: '72%', label: 'of traffic deaths occur in disadvantaged communities', accent: 'rust' },
  { number: '57%', label: 'increase in traffic fatalities from 2017 to 2021', accent: 'rust' },
  { number: '67%', label: 'increase in cycling on this trail during COVID', accent: 'gold' },
  { number: '20%', label: 'of New Orleans households lack access to a vehicle', accent: 'gold' },
  { number: '1 of 2', label: 'most frequently used off-street trails in the city', accent: 'gold' },
];
---

<section class="stats" id="stats">
  <div class="stats-inner">
    <div class="stats-header reveal">
      <p class="section-label">Why It Matters</p>
      <h2 class="stats-heading">By the numbers</h2>
    </div>
    <div class="stats-grid">
      {stats.map((stat, i) => (
        <div class={`stat-card stat-${stat.accent} reveal reveal-delay-${i % 3 + 1}`}>
          <span class="stat-number">{stat.number}</span>
          <span class="stat-label">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stats {
    background: var(--dark);
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
  }

  .stats::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(to right, transparent, rgba(200, 168, 78, 0.3), transparent);
  }

  .stats-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 1.2rem;
  }

  .stats-heading {
    font-family: var(--font-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    line-height: 1.15;
    color: var(--ivory);
    margin-bottom: 3.5rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .stat-card {
    padding: 2.5rem 2rem;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: var(--dark-warm);
    position: relative;
    overflow: hidden;
  }

  .stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
  }

  .stat-rust::before {
    background: linear-gradient(to right, var(--rust), var(--rust-light));
  }

  .stat-gold::before {
    background: linear-gradient(to right, var(--gold-dim), var(--gold));
  }

  .stat-number {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 700;
    line-height: 1;
    margin-bottom: 0.8rem;
  }

  .stat-rust .stat-number {
    color: var(--rust-light);
  }

  .stat-gold .stat-number {
    color: var(--gold);
  }

  .stat-label {
    display: block;
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--text-secondary);
  }

  @media (max-width: 768px) {
    .stats {
      padding: 4rem 1.5rem;
    }
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stats-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
